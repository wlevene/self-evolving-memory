{
  "name": "self-evolving-memory",
  "version": "0.1.0",
  "description": "TypeScript SDK for Self-Evolving Memory System",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "OpenClaw Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/self-evolving-memory"
  },
  "keywords": [
    "ai",
    "memory",
    "agent",
    "mcp",
    "vector"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
